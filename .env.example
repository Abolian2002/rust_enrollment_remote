# Rust enrollment local development config
# Copy this file to .env and fill in local secrets.

PORT=4000
APP_ENV=development
RUST_LOG=api=info,admissions_agent=info,retrieval=info,db=info,tower_http=info

# Comma-separated browser origins allowed to call the API.
# In production, set this to the deployed frontend origin, for example:
# CORS_ALLOWED_ORIGINS=https://enrollment.example.edu.cn
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres connection string. The default local development database used by this project is shown here.
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/hnu_enrollment
DATABASE_MIN_CONNECTIONS=1
DATABASE_MAX_CONNECTIONS=24
DATABASE_ACQUIRE_TIMEOUT_SECS=5

# Runtime limits. Keep these below upstream provider and reverse-proxy timeouts.
CHAT_MAX_CONCURRENT_REQUESTS=40
AGENT_TIMEOUT_SECS=75
CONVERSATION_HISTORY_WINDOW=40
CONVERSATION_TURN_LOCK_MAP_LIMIT=4096
MAJOR_CATALOG_CACHE_TTL_SECS=300
# Leave empty to use APP_ENV defaults: enabled in development, disabled in production.
ENABLE_CLIENT_DIAGNOSTICS=

# OpenAI-compatible DashScope/Bailian chat models.
DASHSCOPE_API_KEY=
OPENAI_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_AGENT_MODEL=qwen-plus
OPENAI_SYNTHESIS_MODEL=qwen-plus
DASHSCOPE_ENABLE_THINKING=false
LLM_PROVIDER=dashscope
LLM_CONNECT_TIMEOUT_SECS=10
LLM_REQUEST_TIMEOUT_SECS=45
LLM_POOL_IDLE_TIMEOUT_SECS=30

# Local embedding service.
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:8114/v1/embeddings
LOCAL_EMBEDDING_MODEL=bge-m3
EMBEDDING_CONNECT_TIMEOUT_SECS=5
EMBEDDING_REQUEST_TIMEOUT_SECS=15
EMBEDDING_POOL_IDLE_TIMEOUT_SECS=30

# TTS token endpoint controls. Leave TTS_TOKEN_AUTH_TOKEN empty for local browser testing.
# If set, callers must send Authorization: Bearer <token> or X-TTS-Auth-Token.
TTS_TOKEN_AUTH_TOKEN=
TTS_TOKEN_RATE_LIMIT_PER_MINUTE=20
TTS_CONNECT_TIMEOUT_SECS=5
TTS_REQUEST_TIMEOUT_SECS=15
TTS_POOL_IDLE_TIMEOUT_SECS=30

# Public frontend config. NEXT_PUBLIC_* values are visible in browser JavaScript; never put secrets here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
